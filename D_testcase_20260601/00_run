#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
LOG_DIR="$ROOT/logs"
CHECKER_LOG="$LOG_DIR/testcase0_checker.log"

mkdir -p "$LOG_DIR"
cd "$ROOT"

make clean
make
./cadd0016 "$ROOT/testcase0" "$ROOT/testcase0/modified_clk_tree.structure"
./checker "$ROOT/testcase0/clk_tree.structure" \
  "$ROOT/testcase0/modified_clk_tree.structure" \
  "$ROOT/testcase0/buf.lib" \
  "$ROOT/testcase0/FF_delay.rpt" \
  "$ROOT/testcase0/SS_delay.rpt" | tee "$CHECKER_LOG"
python3 "$ROOT/analyze_score_terms.py" --label testcase0 "$CHECKER_LOG"
